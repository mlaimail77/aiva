# OpenRouter LLM
OPENAI_API_KEY=your_openrouter_api_key
OPENAI_MODEL=google/gemini-2.0-flash-001

# Cartesia TTS
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE_ID=your_cartesia_voice_id

# LiveKit (optional - for SFU mode)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Model paths
CHECKPOINT_DIR=./checkpoints
WAV2VEC_DIR=./checkpoints/japanese-wav2vec2-base

# GPU settings
CUDA_VISIBLE_DEVICES=0
WORLD_SIZE=1
ICE_PUBLIC_IP=

# TURN server
TURN_PASSWORD=your_secure_password

# Redis
REDIS_PASSWORD=aiva_redis_dev